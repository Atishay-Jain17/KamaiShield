# ─── KamaiShield Environment Config ────────────────────────────
# Copy this to .env and fill in your values before running

# Server
PORT=5000
NODE_ENV=development

# Security — CHANGE THIS IN PRODUCTION (use: openssl rand -hex 64)
JWT_SECRET=kamaishield_super_secret_change_in_production_2026_xyz

# Database
DB_PATH=./kamaishield.db

# API Keys (use free tiers or leave as MOCK for demo mode)
OPENWEATHER_API_KEY=MOCK
OPENAQ_API_KEY=MOCK
NEWS_API_KEY=MOCK

# Razorpay (Test Mode)
RAZORPAY_KEY_ID=MOCK
RAZORPAY_KEY_SECRET=MOCK

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# CORS - comma separated allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
